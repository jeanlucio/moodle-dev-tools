#!/usr/bin/env bash
# Pre-commit: PHPCS + ESLint + lint Mustache (gates determinísticos) e revisão IA paralela
# em PHP, JS, Mustache, CSS e XML. Cada gate só roda se houver arquivo do seu tipo staged.

PHPCS="php -d auto_prepend_file=$HOME/.moodle-dev-tools/phpcs-bootstrap.php /usr/local/bin/phpcs"

ALL_STAGED=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(php|js|mustache|css|xml)$' \
    | grep -v 'amd/build/')
PHP_STAGED=$(echo "$ALL_STAGED" | grep '\.php$')
JS_STAGED=$(echo "$ALL_STAGED" | grep '\.js$')
MUSTACHE_STAGED=$(echo "$ALL_STAGED" | grep '\.mustache$')

# Sem arquivos relevantes staged → nada a fazer
if [ -z "$ALL_STAGED" ]; then
    exit 0
fi

# Procura um caminho relativo subindo a árvore a partir do CWD (raiz do repo no commit).
# Usado para achar o eslint/config do Moodle quando o plugin está montado sob a árvore.
find_up() {
    local rel="$1" dir="$PWD"
    while [ "$dir" != "/" ]; do
        [ -e "$dir/$rel" ] && { printf '%s\n' "$dir/$rel"; return 0; }
        dir=$(dirname "$dir")
    done
    return 1
}

# ------------------------------------------------------------------ #
#  PHPCS — somente PHP, obrigatório, sem bypass                       #
# ------------------------------------------------------------------ #
if [ -n "$PHP_STAGED" ]; then
    echo "phpcs: verificando arquivos staged..."
    echo ""

    PHPCS_ERRORS=0
    while IFS= read -r FILE; do
        [ -f "$FILE" ] || continue
        OUTPUT=$($PHPCS "$FILE" 2>&1)
        if [ $? -ne 0 ]; then
            echo "$OUTPUT"
            echo ""
            PHPCS_ERRORS=1
        fi
    done <<< "$PHP_STAGED"

    if [ $PHPCS_ERRORS -ne 0 ]; then
        echo "--------------------------------------------------------------"
        echo "  Commit bloqueado: corrija os erros acima antes de commitar."
        echo "  Dica: phpcbf pode corrigir automaticamente os [x] marcados."
        echo "--------------------------------------------------------------"
        exit 1
    fi

    echo "phpcs: OK"
fi

# ------------------------------------------------------------------ #
#  ESLint — somente JS staged, espelha o CI (--max-lint-warnings 0)  #
# ------------------------------------------------------------------ #
if [ -n "$JS_STAGED" ]; then
    ESLINT_BIN=$(find_up node_modules/.bin/eslint)
    if [ -z "$ESLINT_BIN" ]; then
        echo "eslint: binário não encontrado na árvore — lint JS pulado"
    else
        echo "eslint: verificando arquivos staged..."
        echo ""

        ESLINT_ERRORS=0
        while IFS= read -r FILE; do
            [ -f "$FILE" ] || continue
            # Captura o RC do eslint direto (sem pipe na mesma linha, senão $? não o reflete);
            # só então filtra o ruído do browserslist da saída exibida.
            OUTPUT=$("$ESLINT_BIN" --max-warnings 0 "$FILE" 2>&1)
            if [ $? -ne 0 ]; then
                printf '%s\n' "$OUTPUT" \
                    | grep -viE 'browserslist|caniuse|update-db|browsers-data'
                echo ""
                ESLINT_ERRORS=1
            fi
        done <<< "$JS_STAGED"

        if [ $ESLINT_ERRORS -ne 0 ]; then
            echo "--------------------------------------------------------------"
            echo "  Commit bloqueado: corrija os erros de ESLint acima."
            echo "--------------------------------------------------------------"
            exit 1
        fi

        echo "eslint: OK"
    fi

    # Aviso (não bloqueia): amd/src editado sem o amd/build correspondente staged.
    # Paths do git são relativos à raiz do repo (sem barra inicial), daí 'amd/src/'.
    SRC_STAGED=$(echo "$JS_STAGED" | grep 'amd/src/')
    if [ -n "$SRC_STAGED" ]; then
        BUILD_STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep 'amd/build/')
        AMD_WARN=0
        while IFS= read -r SRC; do
            [ -z "$SRC" ] && continue
            BUILD="${SRC/amd\/src\//amd\/build\/}"
            BUILD="${BUILD%.js}.min.js"
            if ! printf '%s\n' "$BUILD_STAGED" | grep -qF "$BUILD"; then
                [ $AMD_WARN -eq 0 ] && \
                    echo "aviso: amd/src editado sem o build correspondente staged —"
                echo "  $SRC → rode 'npx grunt amd' e adicione $BUILD"
                AMD_WARN=1
            fi
        done <<< "$SRC_STAGED"
    fi
fi

# ------------------------------------------------------------------ #
#  Mustache — check leve: @template obrigatório, chaves balanceadas  #
# ------------------------------------------------------------------ #
if [ -n "$MUSTACHE_STAGED" ]; then
    echo "mustache: verificando arquivos staged..."

    MUSTACHE_ERRORS=0
    while IFS= read -r FILE; do
        [ -f "$FILE" ] || continue
        # @template é obrigatório — o moodle-plugin-ci mustache falha sem ele.
        if ! grep -q '@template[[:space:]]' "$FILE"; then
            echo "  $FILE: falta @template component/nome no bloco {{! ... }}"
            MUSTACHE_ERRORS=1
        fi
        # Heurística leve de chaves desbalanceadas (apenas aviso, pode ter falso positivo).
        OPEN=$(grep -o '{{' "$FILE" | wc -l)
        CLOSE=$(grep -o '}}' "$FILE" | wc -l)
        if [ "$OPEN" -ne "$CLOSE" ]; then
            echo "  aviso $FILE: chaves mustache possivelmente desbalanceadas (\`{{\`=$OPEN, \`}}\`=$CLOSE)"
        fi
    done <<< "$MUSTACHE_STAGED"

    if [ $MUSTACHE_ERRORS -ne 0 ]; then
        echo "--------------------------------------------------------------"
        echo "  Commit bloqueado: corrija os templates Mustache acima."
        echo "--------------------------------------------------------------"
        exit 1
    fi

    echo "mustache: OK"
fi

# ------------------------------------------------------------------ #
#  Revisão IA — paralela, pode ser ignorada com SKIP_AI=1            #
# ------------------------------------------------------------------ #
if [ "${SKIP_AI}" = "1" ]; then
    echo "revisão IA ignorada (SKIP_AI=1)"
    exit 0
fi

[ -f ~/.phpcs-ai.env ] && source ~/.phpcs-ai.env

GROQ_URL="https://api.groq.com/openai/v1/chat/completions"
GROQ_MODEL="${GROQ_MODEL:-llama-3.3-70b-versatile}"

# Verifica se pelo menos uma chave está configurada
HAS_KEY=0
[ -n "$GEMINI_KEY" ] && HAS_KEY=1
[ -n "$GROQ_KEY" ]   && HAS_KEY=1
for i in "" 2 3 4 5; do
    KEY_VAR="OPENAI${i}_KEY"
    [ -n "${!KEY_VAR}" ] && HAS_KEY=1
done
[ $HAS_KEY -eq 0 ] && exit 0

LICENSE_FILTER='This file is part of Moodle\|Moodle is free software\|GNU General Public License\|along with Moodle\|see <https://www.gnu.org/licenses\|You should have received a copy\|WITHOUT ANY WARRANTY\|the Free Software Foundation'

# Divide o orçamento de 2000 linhas proporcionalmente entre os arquivos.
# Garante que todo arquivo seja representado no diff enviado à IA.
FILE_COUNT=$(echo "$ALL_STAGED" | grep -c .)
LINES_PER_FILE=$(( 2000 / FILE_COUNT ))
[ "$LINES_PER_FILE" -lt 50 ] && LINES_PER_FILE=50

DIFF=""
while IFS= read -r FILE; do
    [ -z "$FILE" ] && continue
    FILE_DIFF=$(git diff --cached -- "$FILE" \
        | grep -v "$LICENSE_FILTER" \
        | head -n "$LINES_PER_FILE")
    [ -n "$FILE_DIFF" ] && DIFF+="${FILE_DIFF}"$'\n'
done <<< "$ALL_STAGED"

[ -z "$DIFF" ] && exit 0

PROMPT_FILE=$(mktemp)
trap "rm -f $PROMPT_FILE ${RESULT_FILES[*]}" EXIT

cat > "$PROMPT_FILE" << 'RULES'
You are a Moodle plugin code reviewer. Analyse the diff below checking ONLY what automated tools do not cover. Be conservative: report only when certain. When in doubt, respond APROVADO, not BLOQUEADO.

=== PHP (*.php) ===
1.  PHPDoc: @param missing description, @return absent when function returns, @var absent on class properties, wrong types (use lowercase int/bool/string, not Int/Bool/String)
2.  $DB->get_record/get_records/get_field inside a foreach/for/while loop — N+1 antipattern
3.  echo $var without s(), format_string() or format_text() — flag only when variable clearly comes from external input or the database
4.  require_sesskey() absent in a block that processes $_POST — flag only when both the processing and the absence are visible in the same diff
5.  User-facing text hardcoded in PHP that should use get_string() — ignore developer error messages (coding_exception, debugging())
6.  Missing type hints or return types on a new function or method added in the diff
7.  SQL built with direct variable concatenation or interpolation (SQL injection risk)
8.  require_capability() or has_capability() absent before an action that modifies data or displays sensitive content — flag only when the absence is clear in the diff
9.  $PAGE->requires->js_call_amd() with a third argument that is an array with more than ~10 keys visible in the diff, or a variable assigned from a bulk DB fetch ($DB->get_records, $DB->get_records_sql, etc.) in the same diff — use a data-* attribute or <script type="application/json"> element instead. Flag only when the large/dynamic data is clearly visible in the diff; ignore scalars, IDs, booleans and small configs
10. Entry-point script (calls require config.php) that renders HTML without calling require_login() — ignore CLI scripts and AJAX handlers
11. unserialize() called with data that may come from external input — use unserialize_object() instead
12. format_text() called with ['noclean' => true] — forbidden without explicit justification
13. require_once or include used to load a file from classes/ — Moodle autoloads via namespace; remove the require_once
14. print_error() called — deprecated since Moodle 4.0; replace with throw new moodle_exception()
15. $DB->get_record() filtering only by ['id' => $var] where $var comes from required_param/optional_param visible in the same diff, without a JOIN or additional instanceid/contextid/courseid filter
16. style="..." attribute on an HTML tag inside a .php or .mustache file — create a semantic class in styles.css instead
17. <script> tag inserted directly in PHP or Mustache — use AMD via $PAGE->requires->js_call_amd()
18. String in lang/pt_br/ using "aluno" or "alunos" — AMOS standard is "estudante"/"estudantes"
19. String added to lang/en/ with no counterpart in lang/pt_br/ — report only when the diff includes changes to both lang/ files

=== JavaScript (amd/src/*.js) ===
20. var declaration — use const by default or let when the variable is reassigned; var is forbidden
21. jQuery.ajax() or execCommand() — forbidden in Moodle
22. Import of core/modal_factory — removed in Moodle 5.2; use core/modal instead
23. Comparison with == or != — use === or !==
24. User-visible UI string hardcoded (not just comments or internal names) — use core/str
25. Long .then().then() chain where async/await would be clearer

=== Mustache (*.mustache) ===
26. @template absent in the second {{! ... }} block of the file
27. Empty heading: <h1> to <h6> with no content, variable or condition
28. sr-only class used alone inside .table, .table-responsive or .activity-item (Boost conflict)
29. Deprecated Bootstrap 4 class: ml-*, mr-*, text-right, float-left, float-right — flag only when used without a Bootstrap 5 equivalent on the same element. For dismiss: flag data-dismiss ONLY when data-bs-dismiss is absent from the same element; having BOTH attributes simultaneously is the correct Moodle cross-version (BS4+BS5) pattern and must NOT be flagged.
30. Decorative icon <i class="fa-..."> or <span class="fa-..."> with no adjacent visible text and no aria-hidden="true"
31. <img> without an alt attribute (decorative: alt=""; descriptive: alt with meaningful text)
32. Button or link containing only an icon with no visible text and no aria-label or <span class="visually-hidden">
33. <th> without scope="col" or scope="row"
34. <input>, <select> or <textarea> without an associated <label> or aria-label — placeholder does not substitute a label

=== CSS (*.css) ===
35. !important — forbidden; resolve the conflict by increasing selector specificity
36. CSS selector without a path-class scope (.path-* or body.path-*) — prevents style leaks to other pages
37. Hardcoded hex value outside var() — e.g. color: #333 should be var(--name, #333); ignore if already inside var()

=== XML (db/*.xml) ===
38. Table name (without the mdl_ prefix) longer than 53 characters
39. Field name longer than 63 characters

=== All file types ===
40. Comment written in Portuguese in any file (// ..., /* ... */, {{! ... }}) — all comments must be in English; flag only when the comment is clearly Portuguese prose, not a single loanword or proper noun

Respond in EXACTLY this format:
- No issues found: first line "APROVADO" and nothing else
- Issues found: first line "BLOQUEADO" followed by a list with "- file:line — description"

Diff to review:
RULES

echo "$DIFF" >> "$PROMPT_FILE"

echo ""
echo "IA: analisando diff..."

PIDS=()
RESULT_FILES=()
STDERR_FILES=()
PROVIDERS=()

start_provider() {
    local provider="$1"; shift
    local result stderr_file
    result=$(mktemp)
    stderr_file=$(mktemp)
    RESULT_FILES+=("$result")
    STDERR_FILES+=("$stderr_file")
    PROVIDERS+=("$provider")
    python3 "$HOME/.moodle-dev-tools/phpcs-ai-call.py" "$@" < "$PROMPT_FILE" > "$result" 2>"$stderr_file" &
    PIDS+=($!)
}

[ -n "$GEMINI_KEY" ] && start_provider "Gemini / gemini-2.0-flash" "gemini" "$GEMINI_KEY"
[ -n "$GROQ_KEY"   ] && start_provider "Groq / ${GROQ_MODEL}" "groq" "$GROQ_KEY" "$GROQ_URL" "$GROQ_MODEL"

for i in "" 2 3 4 5; do
    KEY_VAR="OPENAI${i}_KEY"
    URL_VAR="OPENAI${i}_URL"
    MODEL_VAR="OPENAI${i}_MODEL"
    KEY="${!KEY_VAR}"
    URL="${!URL_VAR}"
    MODEL="${!MODEL_VAR}"
    [ -n "$KEY" ] && start_provider "${MODEL:-OpenAI${i}}" "openai" "$KEY" "$URL" "$MODEL"
done

for PID in "${PIDS[@]}"; do
    wait "$PID"
done

AI_BLOCKED=0
for i in "${!RESULT_FILES[@]}"; do
    RESPONSE=$(cat "${RESULT_FILES[$i]}")

    if [ -z "$RESPONSE" ]; then
        ERR=$(head -1 "${STDERR_FILES[$i]}")
        [ -n "$ERR" ] && echo "[${PROVIDERS[$i]}] falhou: $ERR"
        continue
    fi

    FIRST=$(echo "$RESPONSE" | grep -v '^[[:space:]]*$' | head -n 1 | tr -dc 'A-Z')
    if [ "$FIRST" = "BLOQUEADO" ]; then
        echo ""
        echo "[${PROVIDERS[$i]}] $RESPONSE"
        AI_BLOCKED=1
    elif [ "$FIRST" = "APROVADO" ]; then
        echo "[${PROVIDERS[$i]}] OK"
    else
        # Primeira linha não é APROVADO nem BLOQUEADO: o modelo se perdeu na
        # tarefa ou devolveu lixo. Trata como falha do provider (exibida e
        # ignorada), nunca como aprovação silenciosa.
        echo "[${PROVIDERS[$i]}] resposta ignorada (fora do formato): $(echo "$RESPONSE" | grep -v '^[[:space:]]*$' | head -n 1)"
    fi
done

if [ $AI_BLOCKED -ne 0 ]; then
    echo ""
    echo "--------------------------------------------------------------"
    echo "  Commit bloqueado pela revisão IA."
    echo "  Falso positivo? Use: SKIP_AI=1 git commit -m \"...\""
    echo "--------------------------------------------------------------"
    exit 1
fi

echo "IA: OK"
exit 0
