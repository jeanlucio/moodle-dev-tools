#!/usr/bin/env bash
# Pre-commit: PHPCS (Moodle standard) + revisão IA paralela em PHP, JS, Mustache, CSS e XML.

PHPCS="php -d auto_prepend_file=$HOME/.moodle-dev-tools/phpcs-bootstrap.php /usr/local/bin/phpcs"

ALL_STAGED=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(php|js|mustache|css|xml)$')
PHP_STAGED=$(echo "$ALL_STAGED" | grep '\.php$')

# Sem arquivos relevantes staged → nada a fazer
if [ -z "$ALL_STAGED" ]; then
    exit 0
fi

# ------------------------------------------------------------------ #
#  PHPCS — somente PHP, obrigatório, sem bypass                       #
# ------------------------------------------------------------------ #
if [ -n "$PHP_STAGED" ]; then
    echo "phpcs: verificando arquivos staged..."
    echo ""

    PHPCS_ERRORS=0
    while IFS= read -r FILE; do
        [ -f "$FILE" ] || continue
        OUTPUT=$($PHPCS "$FILE" 2>&1)
        if [ $? -ne 0 ]; then
            echo "$OUTPUT"
            echo ""
            PHPCS_ERRORS=1
        fi
    done <<< "$PHP_STAGED"

    if [ $PHPCS_ERRORS -ne 0 ]; then
        echo "--------------------------------------------------------------"
        echo "  Commit bloqueado: corrija os erros acima antes de commitar."
        echo "  Dica: phpcbf pode corrigir automaticamente os [x] marcados."
        echo "--------------------------------------------------------------"
        exit 1
    fi

    echo "phpcs: OK"
fi

# ------------------------------------------------------------------ #
#  Revisão IA — paralela, pode ser ignorada com SKIP_AI=1            #
# ------------------------------------------------------------------ #
if [ "${SKIP_AI}" = "1" ]; then
    echo "revisão IA ignorada (SKIP_AI=1)"
    exit 0
fi

[ -f ~/.phpcs-ai.env ] && source ~/.phpcs-ai.env

GROQ_URL="https://api.groq.com/openai/v1/chat/completions"
GROQ_MODEL="${GROQ_MODEL:-llama-3.3-70b-versatile}"

# Verifica se pelo menos uma chave está configurada
HAS_KEY=0
[ -n "$GEMINI_KEY" ] && HAS_KEY=1
[ -n "$GROQ_KEY" ]   && HAS_KEY=1
for i in "" 2 3 4 5; do
    KEY_VAR="OPENAI${i}_KEY"
    [ -n "${!KEY_VAR}" ] && HAS_KEY=1
done
[ $HAS_KEY -eq 0 ] && exit 0

LICENSE_FILTER='This file is part of Moodle\|Moodle is free software\|GNU General Public License\|along with Moodle\|see <https://www.gnu.org/licenses\|You should have received a copy\|WITHOUT ANY WARRANTY\|the Free Software Foundation'

DIFF=$(git diff --cached -- '*.php' '*.js' '*.mustache' '*.css' '*.xml' \
    | grep -v "$LICENSE_FILTER" \
    | head -n 700)
[ -z "$DIFF" ] && exit 0

PROMPT_FILE=$(mktemp)
trap "rm -f $PROMPT_FILE ${RESULT_FILES[*]}" EXIT

cat > "$PROMPT_FILE" << 'RULES'
Você é um revisor de código Moodle. Analise o diff abaixo verificando APENAS o que ferramentas automáticas não cobrem. Seja conservador: só reporte quando tiver certeza. Dúvidas devem resultar em APROVADO, não em BLOQUEADO.

=== PHP (*.php) ===
1.  PHPDoc: @param sem descrição, @return ausente quando há return, @var ausente em propriedades de classe, tipos errados (int/bool/string minúsculos, não Int/Bool/String)
2.  Strings lang/: chave nova inserida fora da ordem alfabética estrita no arquivo
3.  $DB->get_record/get_records/get_field dentro de loop foreach/for/while — antipadrão N+1
4.  echo $var sem s(), format_string() ou format_text() — só flagre quando a variável claramente vier de dado externo ou do banco
5.  require_sesskey() ausente em bloco que processa $_POST — só quando o processamento e a ausência são visíveis no mesmo diff
6.  Texto em português ou inglês hardcoded em PHP que deveria usar get_string() — ignorar mensagens de erro de desenvolvedor (coding_exception, debugging())
7.  Type hints e return types ausentes em função ou método novo adicionado no diff
8.  SQL montado com concatenação ou interpolação de variável diretamente na string (risco de injeção SQL)
9.  require_capability() ou has_capability() ausente antes de ação que modifica dados ou exibe conteúdo sensível — só quando a ausência é clara no diff
10. defined('MOODLE_INTERNAL') || die() ausente em arquivo que não é entry point e não define exclusivamente uma classe/interface/trait
11. Script de entrada (chama require config.php) que renderiza HTML sem chamar require_login() — ignorar CLI scripts e AJAX handlers
12. unserialize() chamado com dado que pode vir de entrada externa — usar unserialize_object()
13. format_text() com ['noclean' => true] — proibido sem justificativa explícita
14. require_once ou include para carregar arquivo de classes/ — Moodle faz autoload via namespace; remover o require_once
15. print_error() chamado — depreciado desde Moodle 4.0; substituir por throw new moodle_exception()
16. $DB->get_record() filtrando apenas por ['id' => $var] onde $var vem de required_param/optional_param visível no mesmo diff, sem JOIN ou filtro adicional de instanceid/contextid/courseid
17. Atributo style="..." em tag HTML dentro de arquivo .php ou .mustache — criar classe semântica em styles.css
18. Tag <script> inserida diretamente em PHP ou Mustache — usar AMD via $PAGE->requires->js_call_amd()
19. String em lang/pt_br/ usando "aluno" ou "alunos" — padrão AMOS é "estudante"/"estudantes"
20. String adicionada em lang/en/ sem correspondente em lang/pt_br/ — reportar apenas quando o diff inclui alterações em ambos os arquivos lang/

=== JavaScript (amd/src/*.js) ===
21. var declarado — usar const por padrão ou let quando a variável é reatribuída; var é proibido
22. jQuery.ajax() ou execCommand() chamados — proibidos no Moodle
23. Import de core/modal_factory — removido no Moodle 5.2; usar core/modal
24. Comparação com == ou != — usar === ou !==
25. String de interface visível ao usuário hardcoded (não apenas comentários ou nomes internos) — usar core/str
26. Cadeia longa de .then().then() onde async/await tornaria o código mais legível

=== Mustache (*.mustache) ===
27. @template ausente no segundo bloco {{! ... }} do arquivo
28. Heading vazio: <h1> a <h6> sem conteúdo, variável ou condição
29. Classe sr-only usada sozinha dentro de .table, .table-responsive ou .activity-item (conflito com Boost)
30. Classe Bootstrap 4 depreciada: ml-*, mr-*, text-right, float-left, float-right, ou data-dismiss sem o equivalente data-bs-dismiss
31. Ícone decorativo <i class="fa-..."> ou <span class="fa-..."> sem texto visível adjacente e sem aria-hidden="true"
32. <img> sem atributo alt (decorativas usam alt=""; descritivas precisam de texto no alt)
33. Botão ou link que contém apenas ícone sem texto visível e sem aria-label ou <span class="visually-hidden">
34. <th> sem atributo scope="col" ou scope="row"
35. <input>, <select> ou <textarea> sem <label> associado ou aria-label — placeholder não substitui label

=== CSS (*.css) ===
36. !important — proibido; resolver o conflito aumentando especificidade do seletor
37. Seletor CSS sem escopo de path-class (.path-* ou body.path-*) — previne vazamento de estilos para outras páginas
38. Valor hexadecimal hardcoded fora de var() — ex: color: #333 deve ser var(--nome, #333); ignorar se já está dentro de var()

=== XML (db/*.xml) ===
39. Nome de tabela (sem prefixo mdl_) com mais de 53 caracteres
40. Nome de campo com mais de 63 caracteres

Responda EXATAMENTE neste formato:
- Se não há problemas: primeira linha "APROVADO" e nada mais
- Se há problemas: primeira linha "BLOQUEADO" seguida de lista com "- arquivo:linha — descrição"

Diff a revisar:
RULES

echo "$DIFF" >> "$PROMPT_FILE"

echo ""
echo "IA: analisando diff..."

PIDS=()
RESULT_FILES=()
PROVIDERS=()

start_provider() {
    local provider="$1"; shift
    local result
    result=$(mktemp)
    RESULT_FILES+=("$result")
    PROVIDERS+=("$provider")
    python3 "$HOME/.moodle-dev-tools/phpcs-ai-call.py" "$@" < "$PROMPT_FILE" > "$result" 2>/dev/null &
    PIDS+=($!)
}

[ -n "$GEMINI_KEY" ] && start_provider "Gemini" "gemini" "$GEMINI_KEY"
[ -n "$GROQ_KEY"   ] && start_provider "Groq"   "groq"   "$GROQ_KEY" "$GROQ_URL" "$GROQ_MODEL"

for i in "" 2 3 4 5; do
    KEY_VAR="OPENAI${i}_KEY"
    URL_VAR="OPENAI${i}_URL"
    MODEL_VAR="OPENAI${i}_MODEL"
    KEY="${!KEY_VAR}"
    URL="${!URL_VAR}"
    MODEL="${!MODEL_VAR}"
    [ -n "$KEY" ] && start_provider "OpenAI${i}" "openai" "$KEY" "$URL" "$MODEL"
done

for PID in "${PIDS[@]}"; do
    wait "$PID"
done

AI_BLOCKED=0
for i in "${!RESULT_FILES[@]}"; do
    RESPONSE=$(cat "${RESULT_FILES[$i]}")
    [ -z "$RESPONSE" ] && continue

    FIRST=$(echo "$RESPONSE" | head -n 1 | tr -dc 'A-Z')
    if [ "$FIRST" = "BLOQUEADO" ]; then
        echo ""
        echo "[${PROVIDERS[$i]}] $RESPONSE"
        AI_BLOCKED=1
    fi
done

if [ $AI_BLOCKED -ne 0 ]; then
    echo ""
    echo "--------------------------------------------------------------"
    echo "  Commit bloqueado pela revisão IA."
    echo "  Falso positivo? Use: SKIP_AI=1 git commit -m \"...\""
    echo "--------------------------------------------------------------"
    exit 1
fi

echo "IA: OK"
exit 0
