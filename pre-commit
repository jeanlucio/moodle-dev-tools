#!/usr/bin/env bash
# Pre-commit: PHPCS (Moodle standard) + revisão IA paralela em PHP, JS, Mustache, CSS e XML.

PHPCS="php -d auto_prepend_file=$HOME/.moodle-dev-tools/phpcs-bootstrap.php /usr/local/bin/phpcs"

ALL_STAGED=$(git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(php|js|mustache|css|xml)$' \
    | grep -v 'amd/build/')
PHP_STAGED=$(echo "$ALL_STAGED" | grep '\.php$')

# Sem arquivos relevantes staged → nada a fazer
if [ -z "$ALL_STAGED" ]; then
    exit 0
fi

# ------------------------------------------------------------------ #
#  PHPCS — somente PHP, obrigatório, sem bypass                       #
# ------------------------------------------------------------------ #
if [ -n "$PHP_STAGED" ]; then
    echo "phpcs: verificando arquivos staged..."
    echo ""

    PHPCS_ERRORS=0
    while IFS= read -r FILE; do
        [ -f "$FILE" ] || continue
        OUTPUT=$($PHPCS "$FILE" 2>&1)
        if [ $? -ne 0 ]; then
            echo "$OUTPUT"
            echo ""
            PHPCS_ERRORS=1
        fi
    done <<< "$PHP_STAGED"

    if [ $PHPCS_ERRORS -ne 0 ]; then
        echo "--------------------------------------------------------------"
        echo "  Commit bloqueado: corrija os erros acima antes de commitar."
        echo "  Dica: phpcbf pode corrigir automaticamente os [x] marcados."
        echo "--------------------------------------------------------------"
        exit 1
    fi

    echo "phpcs: OK"
fi

# ------------------------------------------------------------------ #
#  Revisão IA — paralela, pode ser ignorada com SKIP_AI=1            #
# ------------------------------------------------------------------ #
if [ "${SKIP_AI}" = "1" ]; then
    echo "revisão IA ignorada (SKIP_AI=1)"
    exit 0
fi

[ -f ~/.phpcs-ai.env ] && source ~/.phpcs-ai.env

GROQ_URL="https://api.groq.com/openai/v1/chat/completions"
GROQ_MODEL="${GROQ_MODEL:-llama-3.3-70b-versatile}"

# Verifica se pelo menos uma chave está configurada
HAS_KEY=0
[ -n "$GEMINI_KEY" ] && HAS_KEY=1
[ -n "$GROQ_KEY" ]   && HAS_KEY=1
for i in "" 2 3 4 5; do
    KEY_VAR="OPENAI${i}_KEY"
    [ -n "${!KEY_VAR}" ] && HAS_KEY=1
done
[ $HAS_KEY -eq 0 ] && exit 0

LICENSE_FILTER='This file is part of Moodle\|Moodle is free software\|GNU General Public License\|along with Moodle\|see <https://www.gnu.org/licenses\|You should have received a copy\|WITHOUT ANY WARRANTY\|the Free Software Foundation'

# Divide o orçamento de 2000 linhas proporcionalmente entre os arquivos.
# Garante que todo arquivo seja representado no diff enviado à IA.
FILE_COUNT=$(echo "$ALL_STAGED" | grep -c .)
LINES_PER_FILE=$(( 2000 / FILE_COUNT ))
[ "$LINES_PER_FILE" -lt 50 ] && LINES_PER_FILE=50

DIFF=""
while IFS= read -r FILE; do
    [ -z "$FILE" ] && continue
    FILE_DIFF=$(git diff --cached -- "$FILE" \
        | grep -v "$LICENSE_FILTER" \
        | head -n "$LINES_PER_FILE")
    [ -n "$FILE_DIFF" ] && DIFF+="${FILE_DIFF}"$'\n'
done <<< "$ALL_STAGED"

[ -z "$DIFF" ] && exit 0

PROMPT_FILE=$(mktemp)
trap "rm -f $PROMPT_FILE ${RESULT_FILES[*]}" EXIT

cat > "$PROMPT_FILE" << 'RULES'
You are a Moodle plugin code reviewer. Analyse the diff below checking ONLY what automated tools do not cover. Be conservative: report only when certain. When in doubt, respond APROVADO, not BLOQUEADO.

=== PHP (*.php) ===
1.  PHPDoc: @param missing description, @return absent when function returns, @var absent on class properties, wrong types (use lowercase int/bool/string, not Int/Bool/String)
2.  $DB->get_record/get_records/get_field inside a foreach/for/while loop — N+1 antipattern
3.  echo $var without s(), format_string() or format_text() — flag only when variable clearly comes from external input or the database
4.  require_sesskey() absent in a block that processes $_POST — flag only when both the processing and the absence are visible in the same diff
5.  User-facing text hardcoded in PHP that should use get_string() — ignore developer error messages (coding_exception, debugging())
6.  Missing type hints or return types on a new function or method added in the diff
7.  SQL built with direct variable concatenation or interpolation (SQL injection risk)
8.  require_capability() or has_capability() absent before an action that modifies data or displays sensitive content — flag only when the absence is clear in the diff
9.  Entry-point script (calls require config.php) that renders HTML without calling require_login() — ignore CLI scripts and AJAX handlers
10. unserialize() called with data that may come from external input — use unserialize_object() instead
11. format_text() called with ['noclean' => true] — forbidden without explicit justification
12. require_once or include used to load a file from classes/ — Moodle autoloads via namespace; remove the require_once
13. print_error() called — deprecated since Moodle 4.0; replace with throw new moodle_exception()
14. $DB->get_record() filtering only by ['id' => $var] where $var comes from required_param/optional_param visible in the same diff, without a JOIN or additional instanceid/contextid/courseid filter
15. style="..." attribute on an HTML tag inside a .php or .mustache file — create a semantic class in styles.css instead
16. <script> tag inserted directly in PHP or Mustache — use AMD via $PAGE->requires->js_call_amd()
17. String in lang/pt_br/ using "aluno" or "alunos" — AMOS standard is "estudante"/"estudantes"
18. String added to lang/en/ with no counterpart in lang/pt_br/ — report only when the diff includes changes to both lang/ files

=== JavaScript (amd/src/*.js) ===
19. var declaration — use const by default or let when the variable is reassigned; var is forbidden
20. jQuery.ajax() or execCommand() — forbidden in Moodle
21. Import of core/modal_factory — removed in Moodle 5.2; use core/modal instead
22. Comparison with == or != — use === or !==
23. User-visible UI string hardcoded (not just comments or internal names) — use core/str
24. Long .then().then() chain where async/await would be clearer

=== Mustache (*.mustache) ===
25. @template absent in the second {{! ... }} block of the file
26. Empty heading: <h1> to <h6> with no content, variable or condition
27. sr-only class used alone inside .table, .table-responsive or .activity-item (Boost conflict)
28. Deprecated Bootstrap 4 class: ml-*, mr-*, text-right, float-left, float-right — flag only when used without a Bootstrap 5 equivalent on the same element. For dismiss: flag data-dismiss ONLY when data-bs-dismiss is absent from the same element; having BOTH attributes simultaneously is the correct Moodle cross-version (BS4+BS5) pattern and must NOT be flagged.
29. Decorative icon <i class="fa-..."> or <span class="fa-..."> with no adjacent visible text and no aria-hidden="true"
30. <img> without an alt attribute (decorative: alt=""; descriptive: alt with meaningful text)
31. Button or link containing only an icon with no visible text and no aria-label or <span class="visually-hidden">
32. <th> without scope="col" or scope="row"
33. <input>, <select> or <textarea> without an associated <label> or aria-label — placeholder does not substitute a label

=== CSS (*.css) ===
34. !important — forbidden; resolve the conflict by increasing selector specificity
35. CSS selector without a path-class scope (.path-* or body.path-*) — prevents style leaks to other pages
36. Hardcoded hex value outside var() — e.g. color: #333 should be var(--name, #333); ignore if already inside var()

=== XML (db/*.xml) ===
37. Table name (without the mdl_ prefix) longer than 53 characters
38. Field name longer than 63 characters

Respond in EXACTLY this format:
- No issues found: first line "APROVADO" and nothing else
- Issues found: first line "BLOQUEADO" followed by a list with "- file:line — description"

Diff to review:
RULES

echo "$DIFF" >> "$PROMPT_FILE"

echo ""
echo "IA: analisando diff..."

PIDS=()
RESULT_FILES=()
PROVIDERS=()

start_provider() {
    local provider="$1"; shift
    local result
    result=$(mktemp)
    RESULT_FILES+=("$result")
    PROVIDERS+=("$provider")
    python3 "$HOME/.moodle-dev-tools/phpcs-ai-call.py" "$@" < "$PROMPT_FILE" > "$result" 2>/dev/null &
    PIDS+=($!)
}

[ -n "$GEMINI_KEY" ] && start_provider "Gemini" "gemini" "$GEMINI_KEY"
[ -n "$GROQ_KEY"   ] && start_provider "Groq"   "groq"   "$GROQ_KEY" "$GROQ_URL" "$GROQ_MODEL"

for i in "" 2 3 4 5; do
    KEY_VAR="OPENAI${i}_KEY"
    URL_VAR="OPENAI${i}_URL"
    MODEL_VAR="OPENAI${i}_MODEL"
    KEY="${!KEY_VAR}"
    URL="${!URL_VAR}"
    MODEL="${!MODEL_VAR}"
    [ -n "$KEY" ] && start_provider "OpenAI${i}" "openai" "$KEY" "$URL" "$MODEL"
done

for PID in "${PIDS[@]}"; do
    wait "$PID"
done

AI_BLOCKED=0
for i in "${!RESULT_FILES[@]}"; do
    RESPONSE=$(cat "${RESULT_FILES[$i]}")
    [ -z "$RESPONSE" ] && continue

    FIRST=$(echo "$RESPONSE" | head -n 1 | tr -dc 'A-Z')
    if [ "$FIRST" = "BLOQUEADO" ]; then
        echo ""
        echo "[${PROVIDERS[$i]}] $RESPONSE"
        AI_BLOCKED=1
    fi
done

if [ $AI_BLOCKED -ne 0 ]; then
    echo ""
    echo "--------------------------------------------------------------"
    echo "  Commit bloqueado pela revisão IA."
    echo "  Falso positivo? Use: SKIP_AI=1 git commit -m \"...\""
    echo "--------------------------------------------------------------"
    exit 1
fi

echo "IA: OK"
exit 0
