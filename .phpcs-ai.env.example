# Chaves de API para revisão IA no pre-commit.
# Copie este arquivo para ~/.phpcs-ai.env e preencha as chaves que tiver.
# Deixe em branco os providers que não usar.
# O arquivo ~/.phpcs-ai.env NUNCA deve ser commitado — já está no .gitignore.

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_KEY=

# Groq (https://console.groq.com/keys)
GROQ_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Slots OpenAI-compatible (1 a 5).
# Funciona com OpenRouter, NVIDIA NIM, OpenAI, ou qualquer API compatível.
# Exemplos de modelos gratuitos no OpenRouter: deepseek/deepseek-v4-flash,
# openai/gpt-oss-120b:free, meta-llama/llama-3.3-70b-instruct:free

OPENAI_KEY=
OPENAI_URL=https://openrouter.ai/api/v1/chat/completions
OPENAI_MODEL=deepseek/deepseek-v4-flash

OPENAI2_KEY=
OPENAI2_URL=https://openrouter.ai/api/v1/chat/completions
OPENAI2_MODEL=openai/gpt-oss-120b:free

OPENAI3_KEY=
OPENAI3_URL=https://integrate.api.nvidia.com/v1/chat/completions
OPENAI3_MODEL=meta/llama-3.3-70b-instruct

# OPENAI4_KEY=
# OPENAI4_URL=
# OPENAI4_MODEL=

# OPENAI5_KEY=
# OPENAI5_URL=
# OPENAI5_MODEL=

# ---------------------------------------------------------------------------
# Monitor de novos plugins Moodle (plugins-monitor.py)
# Deixe em branco se não usar o monitor.
# ---------------------------------------------------------------------------

# Token do bot Telegram (obter via @BotFather)
TELEGRAM_TOKEN=

# ID do chat que receberá as notificações
# Para descobrir: envie uma mensagem ao bot e acesse
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
